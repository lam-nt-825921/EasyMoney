    <string name="guide_title_default">Hướng dẫn sử dụng</string>
    <string name="guide_title_for_screen">Hướng dẫn %1$s</string>
    <string name="guide_confirm_information_title">Xác nhận thông tin</string>
    <string name="guide_confirm_information_message">Kiểm tra kỹ thông tin cá nhân, khoản vay và phương thức nhận tiền trước khi bấm Xác nhận. Khi xác nhận, hồ sơ sẽ được gửi cho hệ thống thẩm định.</string>
    <string name="guide_contract_title">Hợp đồng vay</string>
    <string name="guide_contract_message">Đọc kỹ điều khoản hợp đồng. Bấm vào liên kết để xem chi tiết. Sau khi đồng ý, bấm Ký hợp đồng để chuyển sang luồng eSign.</string>
    <string name="guide_default_updating_title">Thông tin hướng dẫn đang cập nhật</string>
    <string name="guide_default_updating_message">Nội dung hướng dẫn của trang này sẽ được bổ sung trong phiên bản tiếp theo.</string>
    <string name="guide_edit_contact_info_title">Sửa người liên hệ</string>
    <string name="guide_edit_contact_info_message">Thêm hoặc đổi người liên hệ khẩn cấp. Số điện thoại phải hợp lệ và thuộc về người thân/đồng nghiệp.</string>
    <string name="guide_edit_job_info_title">Sửa công việc &amp; thu nhập</string>
    <string name="guide_edit_job_info_message">Khai báo nghề nghiệp, chức vụ, thu nhập hằng tháng. Thông tin chính xác giúp đánh giá hạn mức tốt hơn.</string>
    <string name="guide_edit_personal_info_title">Sửa thông tin cá nhân</string>
    <string name="guide_edit_personal_info_message">Cập nhật họ tên, ngày sinh, giới tính, CCCD. Một số trường bắt buộc - không thể lưu nếu để trống.</string>
    <string name="guide_event_detail_title">Chi tiết sự kiện</string>
    <string name="guide_event_detail_message">Xem nội dung, thời gian áp dụng và điều kiện tham gia. Bấm Tham gia ngay để đăng ký nếu đủ điều kiện.</string>
    <string name="guide_general_settings_title">Cài đặt chung</string>
    <string name="guide_general_settings_message">Đổi ngôn ngữ, bật/tắt thông báo, đổi chủ đề tối/sáng. Thay đổi được áp dụng ngay sau khi chọn.</string>
    <string name="guide_home_profile">1. Thông tin cá nhân: Hiển thị tên và lời chào dành cho bạn.</string>
    <string name="guide_home_banner">2. Banner quảng cáo: Cập nhật các sự kiện ưu đãi và gói vay mới nhất. Bấm để xem chi tiết.</string>
    <string name="guide_home_rewards">3. Điểm thưởng: Theo dõi số điểm tích lũy và đổi các phần quà giá trị.</string>
    <string name="guide_home_features">4. Chức năng chính:\n- Quản lý khoản vay: Xem các hợp đồng đang thực hiện.\n- Gợi ý khoản vay: Tìm kiếm gói vay phù hợp với hồ sơ của bạn.</string>
    <string name="guide_home_chatbot">5. Tư vấn tài chính: Trò chuyện với chuyên gia tư vấn (Chatbot) để được hỗ trợ 24/7.</string>
    <string name="guide_identity_verification_title">Định danh tài khoản</string>
    <string name="guide_identity_verification_message">Chọn một trong hai cách: quét NFC trên thẻ CCCD hoặc tải ảnh giấy tờ. Chỉ cần một phương thức thành công là đủ.</string>
    <string name="guide_loan_detail_name">1. Tên gói vay: Tên thương hiệu và đối tượng khách hàng phù hợp.</string>
    <string name="guide_loan_detail_specs">2. Thông số vay: Xem chi tiết khoảng hạn mức, kỳ hạn và lãi suất chính xác.</string>
    <string name="guide_loan_detail_conditions">3. Điều kiện đăng ký: Các yêu cầu cơ bản về độ tuổi, thu nhập và lịch sử tín dụng để được duyệt vay.</string>
    <string name="guide_loan_detail_example">4. Ví dụ minh họa: Giúp bạn hình dung số tiền cần trả hàng tháng dựa trên một khoản vay mẫu.</string>
    <string name="guide_loan_detail_register">Bấm \'Đăng ký vay ngay\' để hệ thống kiểm tra điều kiện hồ sơ của bạn.</string>
    <string name="guide_loan_list_title">Danh sách gói vay</string>
    <string name="guide_loan_list_message">Dùng bộ lọc theo hạn mức, kỳ hạn, lãi suất để tìm gói phù hợp. Bấm vào gói để xem chi tiết và đăng ký.</string>
    <string name="guide_loan_management_title">Quản lý khoản vay</string>
    <string name="guide_loan_management_message">Xem các hợp đồng đã được duyệt. Mỗi hợp đồng có hai lựa chọn: hủy hoặc tiến hành ký. Ký xong sẽ chuyển sang luồng eSign.</string>
    <string name="guide_money_management_title">Quản lý nguồn tiền</string>
    <string name="guide_money_management_message">Xem số dư, lịch sử dòng tiền và bật/tắt tự động thanh toán. Bấm Nạp/Rút để chuyển sang màn tương ứng.</string>
    <string name="guide_onboarding_intro">Đây là màn hình tóm tắt thông tin gói vay trước khi bạn tiến hành đăng ký.</string>
    <string name="guide_onboarding_reasons">1. Lý do lựa chọn: Các ưu điểm vượt trội của dịch vụ (nhanh, đơn giản, tin cậy).</string>
    <string name="guide_onboarding_product">2. Thông tin sản phẩm: Hiển thị hạn mức tối đa, kỳ hạn và lãi suất tham khảo.</string>
    <string name="guide_onboarding_provider">3. Thông tin đơn vị cho vay: Tên tổ chức tài chính và thông tin liên hệ chính thức.</string>
    <string name="guide_onboarding_terms">Vui lòng đọc kỹ điều khoản sử dụng trước khi bấm \'Trải nghiệm ngay\' để bắt đầu luồng đăng ký hồ sơ.</string>
    <string name="guide_payment_cards_title">Thẻ thanh toán</string>
    <string name="guide_payment_cards_message">Thêm thẻ mới hoặc xóa thẻ đã liên kết. Thẻ phải được xác minh qua ngân hàng trước khi sử dụng.</string>
    <string name="guide_profile_title">Hồ sơ cá nhân</string>
    <string name="guide_profile_message">Cập nhật thông tin cá nhân, địa chỉ, công việc và tình trạng định danh. Hồ sơ đầy đủ giúp nâng hạn mức và tốc độ phê duyệt.</string>
    <string name="guide_rewards_title">Đổi điểm thưởng</string>
    <string name="guide_rewards_message">Dùng điểm tích lũy để đổi voucher hoặc ưu đãi. Bấm vào quà bạn muốn đổi, xác nhận và làm theo hướng dẫn.</string>
    <string name="guide_security_settings_title">Bảo mật tài khoản</string>
    <string name="guide_security_settings_message">Đổi mật khẩu, bật xác thực sinh trắc học 2FA. Khi bật 2FA, một số thao tác quan trọng sẽ yêu cầu xác thực bằng vân tay hoặc khuôn mặt.</string>
    <string name="guide_top_up_title">Nạp tiền</string>
    <string name="guide_top_up_message">Chọn thẻ nguồn, nhập số tiền cần nạp và xác nhận. Số dư ví sẽ cập nhật sau khi giao dịch thành công.</string>
    <string name="guide_withdraw_title">Rút tiền</string>
    <string name="guide_withdraw_message">Chọn thẻ nhận, nhập số tiền không quá số dư. Nếu bạn đã bật 2FA, cần xác thực sinh trắc học trước khi rút.</string>
