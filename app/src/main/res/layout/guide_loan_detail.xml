<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/guide_title_default"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="1. Tên gói vay: Tên thương hiệu và đối tượng khách hàng phù hợp."
        android:textSize="14sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="2. Thông số vay: Xem chi tiết khoảng hạn mức, kỳ hạn và lãi suất chính xác."
        android:textSize="14sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="3. Điều kiện đăng ký: Các yêu cầu cơ bản về độ tuổi, thu nhập và lịch sử tín dụng để được duyệt vay."
        android:textSize="14sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="4. Ví dụ minh họa: Giúp bạn hình dung số tiền cần trả hàng tháng dựa trên một khoản vay mẫu."
        android:textSize="14sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Bấm 'Đăng ký vay ngay' để hệ thống kiểm tra điều kiện hồ sơ của bạn."
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>
