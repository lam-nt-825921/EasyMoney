<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvGuideTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bảo mật tài khoản"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary" />

    <TextView
        android:id="@+id/tvGuideMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Đổi mật khẩu, bật xác thực sinh trắc học 2FA. Khi bật 2FA, một số thao tác quan trọng sẽ yêu cầu xác thực bằng vân tay hoặc khuôn mặt."
        android:textSize="14sp"
        android:textColor="?android:attr/textColorPrimary" />

</LinearLayout>
