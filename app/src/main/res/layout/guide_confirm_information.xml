<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvGuideTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Xác nhận thông tin"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary" />

    <TextView
        android:id="@+id/tvGuideMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Kiểm tra kỹ thông tin cá nhân, khoản vay và phương thức nhận tiền trước khi bấm Xác nhận. Khi xác nhận, hồ sơ sẽ được gửi cho hệ thống thẩm định."
        android:textSize="14sp"
        android:textColor="?android:attr/textColorPrimary" />

</LinearLayout>
