<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvGuideTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sửa công việc &amp; thu nhập"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary" />

    <TextView
        android:id="@+id/tvGuideMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Khai báo nghề nghiệp, chức vụ, thu nhập hằng tháng. Thông tin chính xác giúp đánh giá hạn mức tốt hơn."
        android:textSize="14sp"
        android:textColor="?android:attr/textColorPrimary" />

</LinearLayout>
